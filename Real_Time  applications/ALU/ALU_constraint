# Clock
#et_property -dict { PACKAGE_PIN N11 IOSTANDARD LVCMOS33 } [get_ports { clk }];

# Inputs A [7:0] mapped to switches sw[0:7]
set_property -dict { PACKAGE_PIN L5  IOSTANDARD LVCMOS33 } [get_ports { a[0] }];
set_property -dict { PACKAGE_PIN L4  IOSTANDARD LVCMOS33 } [get_ports { a[1] }];
set_property -dict { PACKAGE_PIN M4  IOSTANDARD LVCMOS33 } [get_ports { a[2] }];
set_property -dict { PACKAGE_PIN M2  IOSTANDARD LVCMOS33 } [get_ports { a[3] }];
#B
set_property -dict { PACKAGE_PIN M1  IOSTANDARD LVCMOS33 } [get_ports { b[0] }];
set_property -dict { PACKAGE_PIN N3  IOSTANDARD LVCMOS33 } [get_ports { b[1] }];
set_property -dict { PACKAGE_PIN N2  IOSTANDARD LVCMOS33 } [get_ports { b[2] }];
set_property -dict { PACKAGE_PIN N1  IOSTANDARD LVCMOS33 } [get_ports { b[3] }];

# Inputs B [7:0] mapped to switches sw[8:15]
set_property -dict { PACKAGE_PIN P1  IOSTANDARD LVCMOS33 } [get_ports { op[0] }];
set_property -dict { PACKAGE_PIN P4  IOSTANDARD LVCMOS33 } [get_ports { op[1] }];
set_property -dict { PACKAGE_PIN T8  IOSTANDARD LVCMOS33 } [get_ports { op[2] }];
set_property -dict { PACKAGE_PIN R8  IOSTANDARD LVCMOS33 } [get_ports { op[3] }];
#set_property -dict { PACKAGE_PIN N6  IOSTANDARD LVCMOS33 } [get_ports { b[4] }];
#set_property -dict { PACKAGE_PIN T7  IOSTANDARD LVCMOS33 } [get_ports { b[5] }];
#set_property -dict { PACKAGE_PIN P8  IOSTANDARD LVCMOS33 } [get_ports { b[6] }];
#set_property -dict { PACKAGE_PIN M6  IOSTANDARD LVCMOS33 } [get_ports { b[7] }];

# Operation code op[3:0] mapped to pushbuttons pb[0:3]
#set_property -dict { PACKAGE_PIN K13 IOSTANDARD LVCMOS33 PULLDOWN true } [get_ports { op[0] }];
#set_property -dict { PACKAGE_PIN L14 IOSTANDARD LVCMOS33 PULLDOWN true } [get_ports { op[1] }];
#set_property -dict { PACKAGE_PIN M12 IOSTANDARD LVCMOS33 PULLDOWN true } [get_ports { op[2] }];
#set_property -dict { PACKAGE_PIN L13 IOSTANDARD LVCMOS33 PULLDOWN true } [get_ports { op[3] }];

# Outputs y[7:0] mapped to LEDs 0-7
set_property -dict { PACKAGE_PIN J3  IOSTANDARD LVCMOS33 } [get_ports { y[0] }];
set_property -dict { PACKAGE_PIN H3  IOSTANDARD LVCMOS33 } [get_ports { y[1] }];
set_property -dict { PACKAGE_PIN J1  IOSTANDARD LVCMOS33 } [get_ports { y[2] }];
set_property -dict { PACKAGE_PIN K1  IOSTANDARD LVCMOS33 } [get_ports { y[3] }];
set_property -dict { PACKAGE_PIN L3  IOSTANDARD LVCMOS33 } [get_ports { y[4] }];
set_property -dict { PACKAGE_PIN L2  IOSTANDARD LVCMOS33 } [get_ports { y[5] }];
set_property -dict { PACKAGE_PIN K3  IOSTANDARD LVCMOS33 } [get_ports { y[6] }];
set_property -dict { PACKAGE_PIN K2  IOSTANDARD LVCMOS33 } [get_ports { y[7] }];

# Optional flags mapped to extra LEDs (LEDs 8-11)
set_property -dict { PACKAGE_PIN K5  IOSTANDARD LVCMOS33 } [get_ports { carry }];
set_property -dict { PACKAGE_PIN P6  IOSTANDARD LVCMOS33 } [get_ports { zero }];
set_property -dict { PACKAGE_PIN R7  IOSTANDARD LVCMOS33 } [get_ports { borrow}];
set_property -dict { PACKAGE_PIN R6  IOSTANDARD LVCMOS33 } [get_ports { overflow }];
set_property -dict { PACKAGE_PIN T5    IOSTANDARD LVCMOS33 } [get_ports { negative }];
